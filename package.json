{
  "name": "dropship-commerce-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Deployment-ready full-stack ecommerce and dropshipping starter built with Node.js, Express, MongoDB, and a responsive vanilla frontend.",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node scripts/seed.js",
    "check": "node --check src/server.js",
    "smoke": "node scripts/smoke-test.js",
    "test": "npm run smoke"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "supertest": "^7.2.2"
  }
}
